{
  "name": "@ai-ops/web-telemetry-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "浏览器前端遥测 SDK — 采集 Web Vitals、页面性能、前端错误与显式日志",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./transport": "./src/transport/index.ts"
  },
  "scripts": {
