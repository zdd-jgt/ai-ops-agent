{
  "name": "ai-ops-agent",
  "version": "0.0.0",
  "private": true,
  "description": "智能运维大脑 — AI Ops Agent Monorepo",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "pnpm --recursive --parallel dev",
