{
  "name": "@ai-ops/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "智能运维大脑 — 本地 MCP Server（受控只读诊断工具）",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./policy": "./src/policy/index.ts",
    "./tools/frontend-observability": "./src/tools/frontend-observability/index.ts",
    "./tools/*": "./src/tools/*"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
