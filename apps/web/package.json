{
  "name": "@ai-ops/web",
  "version": "0.1.0",
  "private": true,
  "description": "智能运维大脑 — Web 控制台（监控面板、运维聊天）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
