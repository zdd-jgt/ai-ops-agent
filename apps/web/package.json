    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
