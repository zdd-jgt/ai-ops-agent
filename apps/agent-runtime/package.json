{
  "name": "@ai-ops/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "智能运维大脑 — Agent Runtime（Workflow + Agent 编排）",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch src/server.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-ops/auth-contracts": "workspace:*",
    "@ai-ops/mcp-server": "workspace:*",
    "@ai-ops/telemetry-contracts": "workspace:*",
    "@ai-sdk/openai": "^4.0.16",
    "@mastra/core": "^1.51.0",
    "@mastra/libsql": "^1.16.0",
    "@mastra/mcp": "^1.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
