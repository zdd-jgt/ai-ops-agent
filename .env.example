# Optional model providers. Never commit real keys.
DEEPSEEK_API_KEY=
QWEN_API_KEY=
MODEL_PROVIDER=deepseek

# Local OpenAI-compatible model.
LOCAL_MODEL_ENDPOINT=http://localhost:11434/v1
LOCAL_MODEL_NAME=qwen2.5:7b


# Local development identity substitute. Replace with OIDC/BFF session before production.
# These example values are not secrets and must not be reused outside local development.
AIOPS_AUTH_TOKENS_JSON=[{"token":"dev-console-token","subject":"local-console","tenantId":"dev-tenant","roles":["viewer","admin"],"allowedAppIds":["ai-ops-console","demo-app"],"allowedEnvironments":["development","staging","production"]},{"token":"dev-mcp-token","subject":"local-mcp","tenantId":"dev-tenant","roles":["service"],"allowedAppIds":["ai-ops-console","demo-app"],"allowedEnvironments":["development","staging","production"]}]
VITE_AIOPS_DEV_TOKEN=dev-console-token
TELEMETRY_QUERY_TOKEN=dev-mcp-token
MCP_TENANT_ID=dev-tenant

# Public SDK write identifiers are server-bound to tenant/app/environment/origin.
TELEMETRY_WRITE_KEYS_JSON=[{"key":"pub_console","tenantId":"dev-tenant","appId":"ai-ops-console","allowedEnvironments":["development"],"allowedOrigins":["http://localhost:5173"],"allowMissingOrigin":false},{"key":"pub_demo","tenantId":"dev-tenant","appId":"demo-app","allowedEnvironments":["development"],"allowedOrigins":["http://localhost:4173"],"allowMissingOrigin":false}]
AIOPS_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Local telemetry and Agent Runtime.
TELEMETRY_API_URL=http://localhost:3000
AGENT_RUNTIME_PORT=3002

# Server-derived MCP authorization scope. Empty app list fails closed.
MCP_ALLOWED_APP_IDS=demo-app
MCP_ALLOWED_ENVIRONMENTS=development,staging,production
MCP_MAX_TIME_RANGE_MS=3600000
MCP_MAX_CALLS_PER_ROUND=4

# Optional Mastra storage.
# LIBSQL_URL=file:./runtime-data/mastra.db
